[Unit]
Description=GCP Gateway — Google Chat Notification Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=oracle
Group=oinstall
WorkingDirectory=/u01/app/gcp-gateway
EnvironmentFile=/u01/app/gcp-gateway/.env.runtime
ExecStart=/u01/app/gcp-gateway/venv/bin/uvicorn main:app --host 0.0.0.0 --port 2222 --log-level info --no-access-log
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
