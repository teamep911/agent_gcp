# Runtime env for openclaw Agent Monitor (do not put real secrets in git)
ENV=prod
AGENT_HOST=0.0.0.0
AGENT_PORT=2020
PG_DSN=postgresql://monitor_user:***@localhost:5432/monitor_v2
AGENT_WEBHOOK_SECRET=<oem_webhook_secret>
GCP_GATEWAY_BASE_URL=https://gcp.leevo.top
GCP_GATEWAY_SHARED_SECRET=<same_as_gcp_AGENT_SHARED_SECRET>
PERF_BUNDLE_ENABLED=true
PERF_BUNDLE_SCRIPT=/u01/app/agent_monitor/scripts/perf_bundle/capture_perf_bundle_flex.sh
PERF_BUNDLE_TIMEOUT_SECONDS=180
DASHBOARD_JWT_SECRET=<dashboard_jwt_secret>
DASHBOARD_USER=dba
DASHBOARD_PASSWORD=<dashboard_password>
DASHBOARD_COOKIE_SECURE=false
